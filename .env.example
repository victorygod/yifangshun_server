# 微信小程序配置
# 请将你的微信小程序AppId和AppSecret配置到这里
# 然后重命名此文件为 .env

# 微信小程序AppId（在微信公众平台-开发-开发设置中获取）
WECHAT_APPID=your_appid_here

# 微信小程序AppSecret（在微信公众平台-开发-开发设置中获取）
# 注意：AppSecret是敏感信息，请妥善保管，不要泄露
WECHAT_SECRET=your_secret_here

# 数据库配置（可选，如果使用MySQL）
# MYSQL_ADDRESS=127.0.0.1:3306
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=your_password

# 服务端口（可选，默认80）
# PORT=80